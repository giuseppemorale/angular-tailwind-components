{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "angular-tailwind-components": {
      "projectType": "library",
      "root": "projects/angular-tailwind-components",
      "sourceRoot": "projects/angular-tailwind-components/src",
      "prefix": "atc",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-tailwind-components/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-tailwind-components/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-tailwind-components/tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/angular-tailwind-components/.storybook",
            "browserTarget": "angular-tailwind-components:build-storybook-app",
            "tsConfig": "projects/angular-tailwind-components/tsconfig.storybook.json",
            "styles": ["projects/angular-tailwind-components/src/lib/styles/tailwind.css"],
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/angular-tailwind-components/.storybook",
            "browserTarget": "angular-tailwind-components:build-storybook-app",
            "tsConfig": "projects/angular-tailwind-components/tsconfig.storybook.json",
            "styles": ["projects/angular-tailwind-components/src/lib/styles/tailwind.css"],
            "compodoc": false,
            "outputDir": "storybook-static"
          }
        },
        "build-storybook-app": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/angular-tailwind-components/storybook-entry.ts",
            "tsConfig": "projects/angular-tailwind-components/tsconfig.storybook.json",
            "styles": ["projects/angular-tailwind-components/src/lib/styles/tailwind.css"]
          }
        }
      }
    },
    "playground": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "projects/angular-tailwind-components/src/lib/styles/tailwind.css",
              "src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "playground:build:production"
            },
            "development": {
              "buildTarget": "playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
