{
  "name": "angular-tailwind-components",
  "version": "1.2.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve playground",
    "build": "node scripts/copy-icons.js sync && ng build angular-tailwind-components && node scripts/copy-icons.js dist",
    "sync-icons": "node scripts/copy-icons.js sync",
    "watch": "node scripts/copy-icons.js sync && ng build angular-tailwind-components --watch --configuration development && node scripts/copy-icons.js dist",
    "test": "ng test",
    "release": "node scripts/release.js",
    "storybook": "ng run angular-tailwind-components:storybook",
    "build:storybook": "ng run angular-tailwind-components:build-storybook",
    "prettier:write": "prettier --write projects/**/*.{ts,html,scss}",
    "prettier:check": "prettier --check ."
  },
  "private": false,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.10",
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-devkit/core": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@compodoc/compodoc": "^1.2.1",
    "@iconify-json/solar": "^1.2.5",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/angular": "^10.3.6",
    "@tailwindcss/postcss": "^4.2.4",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
