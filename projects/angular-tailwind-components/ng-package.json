{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/angular-tailwind-components",
  "assets": [
    {
      "glob": "**/*.svg",
      "input": "./icons",
      "output": "icons"
    },
    {
      "glob": "tailwind.css",
      "input": "./src/lib/styles",
      "output": "styles"
    }
  ],
  "lib": {
    "entryFile": "src/public-api.ts"
  }
}
